{
  "name": "ultron-hub",
  "version": "9.0.0",
  "description": "The best persistent developer memory for AI agents. Local SQLite + hybrid search + MCP resources. Works with Claude Code, Cursor, and any MCP client.",
  "type": "module",
  "bin": {
    "ultron-hub": "dist/index.js",
    "ultron-daemon": "dist/daemon/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "AGENTS.md",
    "docs",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "smoke": "tsx scripts/smoke-test.ts",
    "init": "node dist/index.js init",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.0.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "cursor",
    "memory",
    "sqlite",
    "developer-tools",
    "ai-tools",
    "context",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StiviMoon/ultron"
  },
  "author": "Steven Villarreal"
}
